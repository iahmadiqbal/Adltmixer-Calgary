# Database Configuration
# IMPORTANT: Set these in Railway Dashboard → Variables
#
# For Local Development:
DATABASE_URL="postgresql://user:password@localhost:5432/adultmixer?schema=public"
#
# For Production (Railway):
# Railway provides DATABASE_URL automatically if you add a PostgreSQL database
# Or set it manually in Variables tab

# JWT Configuration
# CRITICAL: Change this in production! Use a strong random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Frontend URL (for CORS)
# IMPORTANT: Must match your Vercel deployment URL exactly
#
# For Local Development:
FRONTEND_URL="http://localhost:5173"
#
# For Production (Railway):
# Set to your Vercel URL: https://your-app.vercel.app
# No trailing slash!

# Resend API Key (for email verification)
# Get your API key from: https://resend.com/api-keys
# IMPORTANT: Required for email verification to work
RESEND_API_KEY="re_your_api_key_here"

# Node Environment
NODE_ENV="production"

# Port (Railway sets this automatically, but you can override)
PORT=5001
